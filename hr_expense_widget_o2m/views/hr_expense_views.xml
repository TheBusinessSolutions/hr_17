<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Views activated for group_hr_expense_widget_o2m -->
    <!-- When enabled, this view removes the special widget -->
    <!-- and uses the standard one2many widget, which opens a form view instead of inline editing -->
    <record id="view_hr_expense_sheet_form" model="ir.ui.view">
        <field name="name">hr.expense.sheet.form.inherit</field>
        <field name="model">hr.expense.sheet</field>
        <field name="inherit_id" ref="hr_expense.view_hr_expense_sheet_form"/>
        <field name="arch" type="xml">
            <!-- Replace the widget attribute to use standard one2many (opens form view) -->
            <xpath expr="//field[@name='expense_line_ids']" position="replace">
                <field name="expense_line_ids" 
                       groups="hr_expense_widget_o2m.group_hr_expense_widget_o2m"
                       context="{'default_employee_id': employee_id, 'default_company_id': company_id}">
                    <tree string="Expenses">
                        <field name="name"/>
                        <field name="company_id" column_invisible="1"/>
                        <field name="employee_id" column_invisible="1"/>
                        <field name="product_id"/>
                        <field name="date"/>
                        <field name="total_amount" sum="Total"/>
                        <field name="state" widget="badge"/>
                    </tree>
                </field>
            </xpath>
            <!-- For users NOT in the group, keep the original view (with widget) -->
            <xpath expr="//field[@name='expense_line_ids']" position="after">
                <field name="expense_line_ids" 
                       groups="!hr_expense_widget_o2m.group_hr_expense_widget_o2m"
                       widget="section_one2many"
                       context="{'default_employee_id': employee_id, 'default_company_id': company_id}">
                    <tree string="Expenses" editable="bottom">
                        <field name="name"/>
                        <field name="company_id" column_invisible="1"/>
                        <field name="employee_id" column_invisible="1"/>
                        <field name="product_id"/>
                        <field name="date"/>
                        <field name="total_amount" sum="Total"/>
                        <field name="state" widget="badge"/>
                    </tree>
                </field>
            </xpath>
        </field>
    </record>

    <record id="hr_expense_view_form" model="ir.ui.view">
        <field name="name">hr.expense.view.form</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_id']" position="attributes">
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//field[@name='total_amount']" position="attributes">
                <attribute name="force_save">1</attribute>
            </xpath>
            <xpath expr="//field[@name='employee_id']" position="attributes">
                <attribute name="force_save">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>